/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable

# next/og writes the Open Graph / Twitter images as extensionless files
# (/opengraph-image, /twitter-image). Cloudflare Pages needs an explicit
# Content-Type so Facebook/Twitter/Slack unfurlers render them as PNGs.
/opengraph-image
  Content-Type: image/png
  Cache-Control: public, max-age=3600

/twitter-image
  Content-Type: image/png
  Cache-Control: public, max-age=3600

